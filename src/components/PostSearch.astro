---
import type { CollectionEntry } from "astro:content";
import ArrowCard from "@components/ArrowCard.astro";

type Props = {
  posts: CollectionEntry<"blog">[];
  id: string;
}

const { posts, id } = Astro.props;

const fuseData = posts.map(post => ({
  slug: post.slug,
  title: post.data.title,
  description: post.data.description ?? "",
  tags: (post.data.tags ?? []).join(" "),
}));
---

<div class="space-y-4" data-search-root={id}>
  <script type="application/json" data-search-data={id} set:html={JSON.stringify(fuseData)} />
  <input
    id={`search-${id}`}
    type="text"
    placeholder="Buscar..."
    autocomplete="off"
    class="w-full px-3 py-2 text-sm rounded border border-black/15 dark:border-white/20 bg-transparent focus:outline-none focus:ring-1 focus:ring-black/25 dark:focus:ring-white/25 placeholder:opacity-40 transition-colors duration-300"
  />
  <ul id={`list-${id}`} class="flex flex-col gap-4">
    {posts.map(post => (
      <li data-slug={post.slug}>
        <ArrowCard entry={post} />
      </li>
    ))}
  </ul>
  <p id={`empty-${id}`} class="hidden text-sm opacity-50">No se encontraron resultados.</p>
</div>

<script>
  import Fuse from "fuse.js";

  document.querySelectorAll<HTMLDivElement>("[data-search-root]").forEach(root => {
    const id = root.dataset.searchRoot!;
    const dataEl = root.querySelector<HTMLScriptElement>(`[data-search-data="${id}"]`);
    if (!dataEl) return;

    const data: { slug: string; title: string; description: string; tags: string }[] =
      JSON.parse(dataEl.textContent ?? "[]");

    const input = root.querySelector<HTMLInputElement>(`#search-${id}`);
    const list = root.querySelector<HTMLUListElement>(`#list-${id}`);
    const empty = root.querySelector<HTMLParagraphElement>(`#empty-${id}`);
    if (!input || !list || !empty) return;

    const items = Array.from(list.querySelectorAll<HTMLLIElement>("li[data-slug]"));

    const fuse = new Fuse(data, {
      keys: [
        { name: "title", weight: 3 },
        { name: "tags", weight: 2 },
        { name: "description", weight: 1 },
      ],
      threshold: 0.4,
      includeScore: true,
    });

    input.addEventListener("input", () => {
      const query = input.value.trim();
      if (!query) {
        items.forEach(item => item.classList.remove("hidden"));
        empty.classList.add("hidden");
        return;
      }

      const results = fuse.search(query);
      const matchedSlugs = new Set(results.map(r => r.item.slug));

      let visible = 0;
      items.forEach(item => {
        const matches = matchedSlugs.has(item.dataset.slug ?? "");
        item.classList.toggle("hidden", !matches);
        if (matches) visible++;
      });

      empty.classList.toggle("hidden", visible > 0);
    });
  });
</script>
