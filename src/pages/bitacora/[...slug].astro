---
import { type CollectionEntry, getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import ArrowCard from "@components/ArrowCard.astro";
import BackToPrev from "@components/BackToPrev.astro";
import Tag from "@components/Tag.astro";
import { readingTime } from "@lib/utils";
import { BLOG } from "@consts";

export async function getStaticPaths() {
  const posts = (await getCollection("blog"))
    .filter(post => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  const postRoutes = posts.map((post) => {
    const year = post.data.date.getFullYear().toString();
    const sameyear = posts.filter(p => p.data.date.getFullYear().toString() === year);
    const i = sameyear.findIndex(p => p.slug === post.slug);
    return {
      params: { slug: post.slug },
      props: {
        type: "post" as const,
        post,
        prev: sameyear[i + 1] ?? null,
        next: sameyear[i - 1] ?? null,
      },
    };
  });

  const years = [...new Set(posts.map(p => p.data.date.getFullYear().toString()))];
  const yearRoutes = years.map(year => ({
    params: { slug: year },
    props: {
      type: "year" as const,
      year,
      posts: posts.filter(p => p.data.date.getFullYear().toString() === year),
    },
  }));

  return [...postRoutes, ...yearRoutes];
}

type PostProps = {
  type: "post";
  post: CollectionEntry<"blog">;
  prev: CollectionEntry<"blog"> | null;
  next: CollectionEntry<"blog"> | null;
};

type YearProps = {
  type: "year";
  year: string;
  posts: CollectionEntry<"blog">[];
};

type Props = PostProps | YearProps;

const props = Astro.props;

// Render post content only for post pages
const rendered = props.type === "post" ? await props.post.render() : null;
const Content = rendered?.Content;
const postYear = props.type === "post" ? props.post.data.date.getFullYear() : null;
---

{props.type === "year" ? (
  <PageLayout title={`Bitácora ${props.year}`} description={BLOG.DESCRIPTION}>
    <Container>
      <div class="space-y-10">
        <div class="animate">
          <BackToPrev href="/bitacora">
            Volver a bitácora
          </BackToPrev>
        </div>
        <div class="animate font-semibold text-black dark:text-white">
          {props.year}
        </div>
        <div class="animate">
          <ul class="flex flex-col gap-4">
            {props.posts.map(post => (
              <li>
                <ArrowCard entry={post} />
              </li>
            ))}
          </ul>
        </div>
      </div>
    </Container>
  </PageLayout>
) : (
  <PageLayout title={props.post.data.title} description={props.post.data.description}>
    <Container>
      <div class="animate">
        <BackToPrev href={`/bitacora/${postYear}`}>
          Bitácora {postYear}
        </BackToPrev>
      </div>
      <div class="space-y-1 my-10">
        <div class="animate flex items-center gap-1.5">
          <div class="font-base text-sm">
            <FormattedDate date={props.post.data.date} />
          </div>
          &bull;
          <div class="font-base text-sm">
            {readingTime(props.post.body)}
          </div>
        </div>
        <div class="animate text-2xl font-semibold text-black dark:text-white">
          {props.post.data.title}
        </div>
        {props.post.data.tags && props.post.data.tags.length > 0 && (
          <div class="animate flex flex-wrap gap-1.5 mt-2">
            {props.post.data.tags.map(tag => <Tag tag={tag} />)}
          </div>
        )}
      </div>
      <article class="animate">
        {Content && <Content />}
      </article>
      <div class="animate flex gap-4 mt-10">
        {props.prev && (
          <a href={`/bitacora/${props.prev.slug}`} class={`relative group flex items-center pl-8 pr-3 py-2 rounded border border-black/15 dark:border-white/20 hover:bg-black/5 dark:hover:bg-white/5 hover:text-black dark:hover:text-white transition-colors duration-300 ease-in-out min-w-0 ${!props.next ? 'w-1/2' : 'flex-1'}`}>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="absolute top-1/2 left-2 -translate-y-1/2 size-4 stroke-2 fill-none stroke-current">
              <line x1="5" y1="12" x2="19" y2="12" class="translate-x-2 group-hover:translate-x-0 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 ease-in-out" />
              <polyline points="12 5 5 12 12 19" class="translate-x-1 group-hover:translate-x-0 transition-transform duration-300 ease-in-out" />
            </svg>
            <span class="text-sm font-medium truncate">{props.prev.data.title}</span>
          </a>
        )}
        {props.next && (
          <a href={`/bitacora/${props.next.slug}`} class={`relative group flex items-center justify-end pl-3 pr-8 py-2 rounded border border-black/15 dark:border-white/20 hover:bg-black/5 dark:hover:bg-white/5 hover:text-black dark:hover:text-white transition-colors duration-300 ease-in-out min-w-0 ${!props.prev ? 'w-1/2 ml-auto' : 'flex-1'}`}>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="absolute top-1/2 right-2 -translate-y-1/2 size-4 stroke-2 fill-none stroke-current">
              <line x1="5" y1="12" x2="19" y2="12" class="-translate-x-3 group-hover:translate-x-0 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 ease-in-out" />
              <polyline points="12 5 19 12 12 19" class="-translate-x-1 group-hover:translate-x-0 transition-transform duration-300 ease-in-out" />
            </svg>
            <span class="text-sm font-medium truncate">{props.next.data.title}</span>
          </a>
        )}
      </div>
    </Container>
  </PageLayout>
)}
