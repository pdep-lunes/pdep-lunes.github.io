---
import { type CollectionEntry, getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { readingTime } from "@lib/utils";
import BackToPrev from "@components/BackToPrev.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("blog"))
    .filter(post => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      ...post,
      prev: posts[index + 1] ?? null,
      next: posts[index - 1] ?? null,
    },
  }));
}
type Props = CollectionEntry<"blog"> & {
  prev: CollectionEntry<"blog"> | null;
  next: CollectionEntry<"blog"> | null;
};

const { prev, next, ...post } = Astro.props;
const { Content } = await post.render();
const postYear = post.data.date.getFullYear();
---

<PageLayout title={post.data.title} description={post.data.description}>
  <Container>
    <div class="animate">
      <BackToPrev href={`/bitacora/${postYear}`}>
        Bitácora {postYear}
      </BackToPrev>
    </div>
    <div class="space-y-1 my-10">
      <div class="animate flex items-center gap-1.5">
        <div class="font-base text-sm">
          <FormattedDate date={post.data.date} />
        </div>
        &bull;
        <div class="font-base text-sm">
          {readingTime(post.body)}
        </div>
      </div>
      <div class="animate text-2xl font-semibold text-black dark:text-white">
        {post.data.title}
      </div>
    </div>
    <article class="animate">
      <Content />
    </article>
    <div class="animate flex flex-wrap justify-between gap-4 mt-10">
      {prev && (
        <a href={`/bitacora/${prev.slug}`} class="relative group flex-1 min-w-0 flex flex-col pl-4 pr-3 py-2 rounded border border-black/15 dark:border-white/20 hover:bg-black/5 dark:hover:bg-white/5 hover:text-black dark:hover:text-white transition-colors duration-300 ease-in-out">
          <span class="text-xs opacity-60 mb-0.5">anterior</span>
          <span class="text-sm font-medium truncate">{prev.data.title}</span>
        </a>
      )}
      {next && (
        <a href={`/bitacora/${next.slug}`} class="relative group flex-1 min-w-0 flex flex-col items-end pl-3 pr-4 py-2 rounded border border-black/15 dark:border-white/20 hover:bg-black/5 dark:hover:bg-white/5 hover:text-black dark:hover:text-white transition-colors duration-300 ease-in-out">
          <span class="text-xs opacity-60 mb-0.5">siguiente</span>
          <span class="text-sm font-medium truncate">{next.data.title}</span>
        </a>
      )}
    </div>
  </Container>
</PageLayout>